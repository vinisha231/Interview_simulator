<?xml version="1.0" encoding="utf-8"?>
<!--
Azure Web.config Configuration File
==================================

This file configures how Azure App Service runs our Python FastAPI application.
It tells Azure:
1. How to handle Python requests
2. What command to run to start our application
3. Where to log output and errors
4. How long to wait for the app to start

Key Elements:
- handlers: Tells IIS (Azure's web server) how to handle requests
- httpPlatform: Specifies the command to run our Python application
- Environment variables: %PORT%, %HOME% are set by Azure automatically

Author: LLM Interview Simulator Team
-->
<configuration>
  <system.webServer>
    <!-- Configure handlers for Python requests -->
    <handlers>
      <!-- 
      This handler tells Azure to process all requests (*) with all HTTP verbs (*)
      using the httpPlatformHandler module, which can run Python applications
      -->
      <add name="PythonHandler" 
           path="*" 
           verb="*" 
           modules="httpPlatformHandler" 
           resourceType="Unspecified"/>
    </handlers>
    
    <!-- Configure the HTTP platform (how to run our Python app) -->
    <httpPlatform 
      <!-- Path to Python executable (Azure provides this) -->
      processPath="%AZURE_FUNCTIONS_RUNTIME_PATH%\python.exe"
      
      <!-- Command line arguments to start our FastAPI app -->
      arguments="%AZURE_FUNCTIONS_RUNTIME_PATH%\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port %HTTP_PLATFORM_PORT%"
      
      <!-- Enable logging to help with debugging -->
      stdoutLogEnabled="true"
      
      <!-- Where to save log files (Azure provides the HOME path) -->
      stdoutLogFile="%HOME%\LogFiles\stdout"
      
      <!-- How long to wait for the app to start (60 seconds) -->
      startupTimeLimit="60"
      
      <!-- How many times to retry if startup fails (3 attempts) -->
      startupRetryCount="3">
    </httpPlatform>
  </system.webServer>
</configuration>
