# Copy to .env and fill in values. Do not commit .env.

# Required: database (login/register and sessions need this)
DATABASE_URL=postgresql://user:password@localhost:5432/interview_simulator

# Auth (optional; random key used if SECRET_KEY not set)
SECRET_KEY=your-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
PORT=8000

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# AWS Bedrock (for AI questions and evaluation)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Optional (legacy / other)
# OPENAI_API_KEY=your_openai_api_key_here
# ENVIRONMENT=development
