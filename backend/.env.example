# Database (Required)
DATABASE_URL=postgresql://username:password@localhost:5432/interview_simulator

# JWT Authentication (Required for production - auto-generated if not set)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS Configuration (Required for Bedrock, Polly, Transcribe)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Bedrock LLM Model (Optional - defaults to Claude 3 Sonnet)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# CORS (Optional - defaults to * for development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Port (Optional - defaults to 8000)
PORT=8000
